# =====================================================
# QR Service Platform - Environment Configuration
# =====================================================

# Application
NODE_ENV=development
PORT=3000
APP_NAME="QR Service Platform"
APP_URL=http://localhost:3000
API_VERSION=v1

# =====================================================
# Database Configuration
# =====================================================

# PostgreSQL (Primary Database)
DATABASE_URL="postgresql://postgres:password@localhost:5432/qr_service_platform?schema=public"
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=qr_service_platform
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_IDLE_TIMEOUT=30000

# MongoDB (Event Store & Logs)
MONGODB_URI="mongodb://localhost:27017/qr_service_platform"
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=qr_service_platform
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=5

# Redis (Cache & Pub/Sub)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=50

# =====================================================
# Authentication & Security
# =====================================================

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_change_in_production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_characters
JWT_REFRESH_TOKEN_EXPIRY=30d

# Bcrypt
BCRYPT_ROUNDS=12

# Session
SESSION_SECRET=your_session_secret_key_min_32_characters

# =====================================================
# External Services
# =====================================================

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=qr-service-platform

# PayOS (Payment Gateway)
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=http://localhost:3000/api/v1/payments/callback
PAYOS_CANCEL_URL=http://localhost:3000/api/v1/payments/cancel
PAYOS_WEBHOOK_URL=http://localhost:3000/api/v1/webhooks/payos

# Email Service (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME="QR Service Platform"
SMTP_FROM_EMAIL=noreply@qrservice.com

# SMS Service (Optional)
SMS_PROVIDER=twilio
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret
SMS_FROM_NUMBER=+1234567890

# =====================================================
# WebSocket Configuration
# =====================================================

WS_PORT=3001
WS_PATH=/socket.io
WS_CORS_ORIGIN=http://localhost:5173,http://localhost:3000
WS_PING_TIMEOUT=60000
WS_PING_INTERVAL=25000

# =====================================================
# CORS Configuration
# =====================================================

CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# =====================================================
# Rate Limiting
# =====================================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# =====================================================
# Logging Configuration
# =====================================================

LOG_LEVEL=debug
LOG_DIR=logs
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m
LOG_QUERIES=false

# =====================================================
# Cache Configuration
# =====================================================

CACHE_TTL_DEFAULT=3600
CACHE_TTL_MENU=7200
CACHE_TTL_TABLE=1800
CACHE_TTL_SESSION=86400

# =====================================================
# File Upload
# =====================================================

MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif
UPLOAD_DIR=uploads

# =====================================================
# Queue Configuration (Bull)
# =====================================================

QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_DB=1

# =====================================================
# Feature Flags
# =====================================================

ENABLE_SWAGGER=true
ENABLE_ANALYTICS=true
ENABLE_VOICE_ORDERING=false
ENABLE_SOCIAL_DINING=false
ENABLE_MINI_GAMES=false
ENABLE_LIVESTREAM=false

# =====================================================
# Business Configuration
# =====================================================

# Tax & Service Charge
TAX_RATE=0.10
SERVICE_CHARGE_RATE=0.05

# Order Configuration
ORDER_TIMEOUT_MINUTES=120
ORDER_CANCELLATION_WINDOW_MINUTES=5

# Payment Configuration
PAYMENT_TIMEOUT_MINUTES=15
PAYMENT_RETRY_ATTEMPTS=3

# Reservation Configuration
RESERVATION_BUFFER_HOURS=2
RESERVATION_MAX_ADVANCE_DAYS=30

# =====================================================
# Monitoring & Observability
# =====================================================

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# New Relic (APM)
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=qr-service-platform

# =====================================================
# Development Tools
# =====================================================

# Debug
DEBUG=false
DEBUG_PORT=9229

# Hot Reload
WATCH_MODE=true

# =====================================================
# Production Overrides
# =====================================================

# Set these in production environment
# NODE_ENV=production
# LOG_LEVEL=info
# LOG_QUERIES=false
# ENABLE_SWAGGER=false
# DEBUG=false
