{
  "name": "qr-service-platform",
  "version": "1.0.0",
  "description": "Multi-Branch QR Service Platform for Restaurants - Production SaaS",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:prod": "NODE_ENV=production node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "db:setup": "node scripts/setup-mongodb.js",
    "db:migrate": "node scripts/migrate-postgres-to-mongodb.js",
    "db:migrate:verify": "node scripts/migrate-postgres-to-mongodb.js verify",
    "db:seed": "node scripts/seed.js",
    "db:test": "node scripts/test-mongodb-connection.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "type-check": "tsc --noEmit --allowJs --checkJs",
    "docker:dev": "docker-compose -f docker/docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f docker/docker-compose.yml up",
    "docker:build": "docker build -f docker/Dockerfile -t qr-service-platform .",
    "logs": "pm2 logs",
    "monitor": "pm2 monit"
  },
  "keywords": [
    "restaurant",
    "qr-code",
    "saas",
    "multi-tenant",
    "nodejs",
    "javascript",
    "clean-architecture"
  ],
  "author": "QR Service Platform Team",
  "license": "PROPRIETARY",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.1",
    "@fastify/websocket": "^10.0.1",
    "@payos/node": "^2.0.5",
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "cloudinary": "^2.9.0",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "fastify": "^4.25.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.19.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.6.1",
    "socket.io-redis": "^6.1.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.0",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^48.0.2",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.1.1",
    "prisma": "^5.22.0",
    "typescript": "^5.3.3"
  }
}
