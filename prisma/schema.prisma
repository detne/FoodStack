generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model activity_logs {
  id            String   @id
  user_id       String?
  restaurant_id String?
  branch_id     String?
  action        String
  entity_type   String
  entity_id     String?
  old_values    Json?
  new_values    Json?
  ip_address    String?
  user_agent    String?
  created_at    DateTime @default(now())

  @@index([created_at])
  @@index([restaurant_id])
  @@index([user_id])
}

model areas {
  id         String    @id
  branch_id  String
  name       String
  sort_order Int       @default(0)
  created_at DateTime  @default(now())
  updated_at DateTime
  deleted_at DateTime?
  branches   branches  @relation(fields: [branch_id], references: [id])
  tables     tables[]
}

model branches {
  id            String       @id
  restaurant_id String
  name          String
  address       String
  phone         String?
  status        String       @default("ACTIVE")
  created_at    DateTime     @default(now())
  updated_at    DateTime
  deleted_at    DateTime?
  areas         areas[]
  restaurants   restaurants  @relation(fields: [restaurant_id], references: [id])
  categories    categories[]
  orders        orders[]
}

model categories {
  id          String       @id
  branch_id   String
  name        String
  description String?
  sort_order  Int          @default(0)
  created_at  DateTime     @default(now())
  updated_at  DateTime
  deleted_at  DateTime?
  branches    branches     @relation(fields: [branch_id], references: [id])
  menu_items  menu_items[]
}

model customization_groups {
  id                       String                     @id
  name                     String
  description              String?
  min_select               Int                        @default(0)
  max_select               Int                        @default(1)
  is_required              Boolean                    @default(false)
  created_at               DateTime                   @default(now())
  updated_at               DateTime
  customization_options    customization_options[]
  menu_item_customizations menu_item_customizations[]
}

model customization_options {
  id                     String               @id
  customization_group_id String
  name                   String
  price_delta            Decimal              @default(0) @db.Decimal(10, 2)
  sort_order             Int                  @default(0)
  is_available           Boolean              @default(true)
  created_at             DateTime             @default(now())
  updated_at             DateTime
  customization_groups   customization_groups @relation(fields: [customization_group_id], references: [id])
}

model feedbacks {
  id              String    @id
  order_id        String
  restaurant_id   String
  branch_id       String
  customer_name   String?
  customer_email  String?
  overall_rating  Int
  food_rating     Int?
  service_rating  Int?
  ambiance_rating Int?
  comment         String?
  dish_ratings    Json?
  sentiment       String?
  is_anonymous    Boolean   @default(false)
  response        String?
  responded_at    DateTime?
  responded_by    String?
  created_at      DateTime  @default(now())
  updated_at      DateTime
}

model invoices {
  id             String    @id
  order_id       String    @unique
  invoice_number String    @unique
  customer_name  String?
  customer_email String?
  customer_phone String?
  subtotal       Decimal   @db.Decimal(10, 2)
  tax            Decimal   @db.Decimal(10, 2)
  service_charge Decimal   @db.Decimal(10, 2)
  total          Decimal   @db.Decimal(10, 2)
  status         String    @default("UNPAID")
  issued_at      DateTime  @default(now())
  paid_at        DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime
}

model menu_item_customizations {
  id                     String               @id
  menu_item_id           String
  customization_group_id String
  created_at             DateTime             @default(now())
  customization_groups   customization_groups @relation(fields: [customization_group_id], references: [id])

  @@unique([menu_item_id, customization_group_id])
}

model menu_items {
  id          String        @id
  category_id String
  name        String
  description String?
  price       Decimal       @db.Decimal(10, 2)
  image_url   String?
  available   Boolean       @default(true)
  created_at  DateTime      @default(now())
  updated_at  DateTime
  deleted_at  DateTime?
  categories  categories    @relation(fields: [category_id], references: [id])
  order_items order_items[]
}

model notifications {
  id            String    @id
  user_id       String?
  restaurant_id String?
  branch_id     String?
  type          String
  title         String
  message       String
  data          Json?
  is_read       Boolean   @default(false)
  read_at       DateTime?
  created_at    DateTime  @default(now())
}

model order_item_customizations {
  id                      String   @id
  order_item_id           String
  customization_option_id String
  price_delta             Decimal  @db.Decimal(10, 2)
  created_at              DateTime @default(now())
}

model order_items {
  id           String     @id
  order_id     String
  menu_item_id String
  quantity     Int
  price        Decimal    @db.Decimal(10, 2)
  subtotal     Decimal    @db.Decimal(10, 2)
  notes        String?
  created_at   DateTime   @default(now())
  menu_items   menu_items @relation(fields: [menu_item_id], references: [id])
  orders       orders     @relation(fields: [order_id], references: [id])
}

model orders {
  id             String        @id
  branch_id      String
  table_id       String
  order_number   String        @unique
  status         String        @default("PENDING")
  subtotal       Decimal       @db.Decimal(10, 2)
  tax            Decimal       @db.Decimal(10, 2)
  service_charge Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  payment_status String        @default("UNPAID")
  created_at     DateTime      @default(now())
  updated_at     DateTime
  order_items    order_items[]
  branches       branches      @relation(fields: [branch_id], references: [id])
  tables         tables        @relation(fields: [table_id], references: [id])
  payments       payments?
}

model payments {
  id              String   @id
  order_id        String   @unique
  amount          Decimal  @db.Decimal(10, 2)
  method          String
  status          String   @default("PENDING")
  transaction_ref String?  @unique
  payos_data      Json?
  idempotency_key String   @unique
  created_at      DateTime @default(now())
  updated_at      DateTime
  orders          orders   @relation(fields: [order_id], references: [id])
}

model permissions {
  id               String             @id
  name             String             @unique
  description      String?
  resource         String
  action           String
  created_at       DateTime           @default(now())
  user_permissions user_permissions[]
}

model reservations {
  id               String   @id
  branch_id        String
  table_id         String
  customer_name    String
  customer_phone   String
  customer_email   String?
  party_size       Int
  reservation_date DateTime
  reservation_time String
  status           String   @default("PENDING")
  notes            String?
  created_at       DateTime @default(now())
  updated_at       DateTime
}

model restaurants {
  id                String         @id
  name              String
  email             String         @unique
  phone             String?
  address           String?
  logo_url          String?
  email_verified    Boolean        @default(false)
  email_verified_at DateTime?
  subscription_id   String?
  created_at        DateTime       @default(now())
  updated_at        DateTime
  deleted_at        DateTime?
  branches          branches[]
  subscriptions     subscriptions? @relation(fields: [subscription_id], references: [id])
  users             users[]
}

model roles {
  id               String             @id
  name             String             @unique
  description      String?
  created_at       DateTime           @default(now())
  updated_at       DateTime
  user_permissions user_permissions[]
}

model subscription_feature_limits {
  id                   String             @id
  subscription_plan_id String
  feature_name         String
  limit_value          Int
  created_at           DateTime           @default(now())
  subscription_plans   subscription_plans @relation(fields: [subscription_plan_id], references: [id])

  @@unique([subscription_plan_id, feature_name])
}

model subscription_plans {
  id                          String                        @id
  name                        String                        @unique
  description                 String?
  price                       Decimal                       @db.Decimal(10, 2)
  billing_cycle               String
  max_branches                Int                           @default(1)
  max_tables                  Int                           @default(10)
  max_menu_items              Int                           @default(50)
  features                    Json?
  is_active                   Boolean                       @default(true)
  created_at                  DateTime                      @default(now())
  updated_at                  DateTime
  subscription_feature_limits subscription_feature_limits[]
}

model subscriptions {
  id            String        @id
  restaurant_id String        @unique
  plan_type     String
  status        String        @default("ACTIVE")
  start_date    DateTime
  end_date      DateTime
  max_branches  Int           @default(1)
  max_tables    Int           @default(10)
  created_at    DateTime      @default(now())
  updated_at    DateTime
  restaurants   restaurants[]
}

model tables {
  id           String    @id
  area_id      String
  table_number String
  capacity     Int       @default(4)
  qr_token     String    @unique
  qr_code_url  String?
  status       String    @default("AVAILABLE")
  created_at   DateTime  @default(now())
  updated_at   DateTime
  deleted_at   DateTime?
  orders       orders[]
  areas        areas     @relation(fields: [area_id], references: [id])
}

model user_permissions {
  id            String      @id
  user_id       String
  role_id       String
  permission_id String
  created_at    DateTime    @default(now())
  permissions   permissions @relation(fields: [permission_id], references: [id])
  roles         roles       @relation(fields: [role_id], references: [id])

  @@unique([user_id, role_id, permission_id])
}

model users {
  id            String      @id
  restaurant_id String
  email         String      @unique
  password_hash String
  full_name     String
  phone         String?
  role          String      @default("STAFF")
  status        String      @default("ACTIVE")
  last_login_at DateTime?
  created_at    DateTime    @default(now())
  updated_at    DateTime
  deleted_at    DateTime?
  restaurants   restaurants @relation(fields: [restaurant_id], references: [id])
}
